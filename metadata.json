// --- src/App.tsx ---
import React, { useState, useEffect, useMemo } from 'react';
import { 
  FlaskConical, 
  Clock, 
  ArrowRightLeft, 
  Wind, 
  Play, 
  RotateCcw, 
  Trash2, 
  Plus, 
  ChevronRight,
  MonitorPlay,
  CheckCircle2,
  AlertCircle,
  Database
} from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';
import { format, addMinutes } from 'date-fns';
import { cn, formatTime } from './lib/utils';

// --- 实验参数 (秒/分钟为单位) ---
const DURATIONS = {
  PUMPING: 50 * 60,         // 抽气 50min
  ACID_DIGESTION: 30 * 60,  // 酸解 30min
  EXCHANGE: 50 * 60,        // 交换 50min
  TEST_O2: 120,             // 测氧气 120min (2h)
  TEST_CO2_PRE: 15,         // 测酸解CO2 15min
  TEST_CO2_POST: 60,        // 测交换后CO2 60min (1h)
};

type SampleType = 'ACID_CO2' | 'EXCHANGE_CO2' | 'EXCHANGE_O2';

interface Sample {
  id: string;
  name: string;
  type: SampleType;
  status: 'pending' | 'testing' | 'completed';
  recordedAt: Date;
}

interface TimerState {
  id: string;
  name: string;
  totalSeconds: number;
  remainingSeconds: number;
  isRunning: boolean;
  type: 'pumping' | 'acid' | 'exchange';
}

export default function App() {
  const [samples, setSamples] = useState<Sample[]>([]);
  const [timers, setTimers] = useState<TimerState[]>([
    { id: '1', name: '酸解线抽气', totalSeconds: DURATIONS.PUMPING, remainingSeconds: DURATIONS.PUMPING, isRunning: false, type: 'pumping' },
    { id: '2', name: '交换线抽气', totalSeconds: DURATIONS.PUMPING, remainingSeconds: DURATIONS.PUMPING, isRunning: false, type: 'pumping' },
    { id: '3', name: '碳酸岩酸解', totalSeconds: DURATIONS.ACID_DIGESTION, remainingSeconds: DURATIONS.ACID_DIGESTION, isRunning: false, type: 'acid' },
    { id: '4', name: '氧气交换反应', totalSeconds: DURATIONS.EXCHANGE, remainingSeconds: DURATIONS.EXCHANGE, isRunning: false, type: 'exchange' },
  ]);

  const [newSampleName, setNewSampleName] = useState('');
  const [newSampleType, setNewSampleType] = useState<SampleType>('ACID_CO2');

  // --- 计时器核心逻辑 ---
  useEffect(() => {
    const interval = setInterval(() => {
      setTimers(prev => prev.map(t => {
        if (t.isRunning && t.remainingSeconds > 0) {
          return { ...t, remainingSeconds: t.remainingSeconds - 1 };
        }
        if (t.isRunning && t.remainingSeconds === 0) return { ...t, isRunning: false };
        return t;
      }));
    }, 1000);
    return () => clearInterval(interval);
  }, []);

  const toggleTimer = (id: string) => {
    setTimers(prev => prev.map(t => t.id === id ? { ...t, isRunning: !t.isRunning } : t));
  };

  const resetTimer = (id: string) => {
    setTimers(prev => prev.map(t => t.id === id ? { ...t, remainingSeconds: t.totalSeconds, isRunning: false } : t));
  };

  // --- 样品记录逻辑 ---
  const addSample = () => {
    if (!newSampleName.trim()) return;
    const sample: Sample = {
      id: Math.random().toString(36).substr(2, 9),
      name: newSampleName,
      type: newSampleType,
      status: 'pending',
      recordedAt: new Date(),
    };
    setSamples([...samples, sample]);
    setNewSampleName('');
  };

  const removeSample = (id: string) => setSamples(samples.filter(s => s.id !== id));
  const updateStatus = (id: string, status: Sample['status']) => 
    setSamples(samples.map(s => s.id === id ? { ...s, status } : s));

  // --- 上机测试序列预测 ---
  const timelinePrediction = useMemo(() => {
    let currentTime = new Date();
    const schedule = [];
    const pendingSamples = samples.filter(s => s.status !== 'completed');

    for (const sample of pendingSamples) {
      const duration = {
        'ACID_CO2': DURATIONS.TEST_CO2_PRE,
        'EXCHANGE_CO2': DURATIONS.TEST_CO2_POST,
        'EXCHANGE_O2': DURATIONS.TEST_O2,
      }[sample.type];

      const start = currentTime;
      const end = addMinutes(start, duration);
      
      schedule.push({
        id: sample.id,
        name: sample.name,
        type: sample.type,
        start,
        end,
        duration
      });
      currentTime = end;
    }
    return schedule;
  }, [samples]);

  return (
    <div className="min-h-screen bg-[#F8FAFC] text-slate-900 font-sans p-4 md:p-8">
      {/* 顶部导航 */}
      <header className="max-w-7xl mx-auto mb-8 flex flex-col md:flex-row md:items-center justify-between gap-4 border-b border-slate-200 pb-6">
        <div>
          <h1 className="text-3xl font-bold tracking-tight flex items-center gap-2">
            <FlaskConical className="text-blue-600" />
            地球化学实验助手
            <span className="text-xs font-mono bg-blue-100 text-blue-700 px-2 py-1 rounded ml-2">v1.1</span>
          </h1>
          <p className="text-slate-500 mt-1">碳酸岩酸解 - 氧交换 - 质谱测试全流程排程</p>
        </div>
        <div className="bg-white border px-4 py-2 rounded-xl shadow-sm flex items-center gap-3">
          <div className="text-right">
            <div className="text-[10px] text-slate-400 font-bold uppercase">当前实验室时间</div>
            <div className="text-xl font-mono font-bold">{format(new Date(), 'HH:mm:ss')}</div>
          </div>
        </div>
      </header>

      <main className="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-6">
        
        {/* 左侧控制区 */}
        <div className="lg:col-span-4 space-y-6">
          
          {/* 1. 实验计时器 */}
          <section className="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
            <h2 className="text-lg font-bold mb-4 flex items-center gap-2">
              <Clock className="w-5 h-5 text-blue-500" /> 实验过程计时
            </h2>
            <div className="space-y-3">
              {timers.map(timer => (
                <div key={timer.id} className="p-4 rounded-xl border border-slate-100 bg-slate-50 group transition-all hover:bg-white hover:shadow-md">
                  <div className="flex justify-between items-center mb-1">
                    <span className="text-xs font-bold text-slate-500">{timer.name}</span>
                    <span className="font-mono text-lg font-bold tabular-nums text-slate-800">
                      {formatTime(timer.remainingSeconds)}
                    </span>
                  </div>
                  <div className="w-full h-1.5 bg-slate-200 rounded-full overflow-hidden mb-3">
                    <motion.div 
                      className={cn(
                        "h-full rounded-full",
                        timer.type === 'pumping' ? "bg-cyan-400" : 
                        timer.type === 'acid' ? "bg-amber-400" : "bg-indigo-400"
                      )}
                      initial={{ width: 0 }}
                      animate={{ width: `${(timer.remainingSeconds / timer.totalSeconds) * 100}%` }}
                    />
                  </div>
                  <div className="flex gap-2">
                    <button 
                      onClick={() => toggleTimer(timer.id)}
                      className={cn(
                        "flex-1 flex items-center justify-center gap-2 py-2 rounded-lg text-sm font-bold transition-all",
                        timer.isRunning 
                          ? "bg-slate-200 text-slate-700 active:scale-95"
                          : "bg-blue-600 text-white hover:bg-blue-700 active:scale-95 shadow-sm"
                      )}
                    >
                      {timer.isRunning ? <Clock className="w-4 h-4 animate-pulse" /> : <Play className="w-4 h-4" />}
                      {timer.isRunning ? "暂停" : "开始"}
                    </button>
                    <button 
                      onClick={() => resetTimer(timer.id)}
                      className="p-2 border border-slate-200 rounded-lg hover:bg-slate-100 transition-colors"
                      title="重置"
                    >
                      <RotateCcw className="w-4 h-4 text-slate-400" />
                    </button>
                  </div>
                </div>
              ))}
            </div>
          </section>

          {/* 2. 样品录入 */}
          <section className="bg-white rounded-2xl shadow-sm border border-slate-200 p-5">
            <h2 className="text-lg font-bold mb-4 flex items-center gap-2">
              <Plus className="w-5 h-5 text-emerald-500" /> 样品记录 (打点)
            </h2>
            <div className="space-y-4">
              <div>
                <label className="text-[10px] font-bold text-slate-400 uppercase mb-1 block">样品编号/名称</label>
                <input 
                  type="text" 
                  value={newSampleName}
                  onChange={(e) => setNewSampleName(e.target.value)}
                  placeholder="例如: S0508-01"
                  className="w-full px-4 py-3 rounded-xl border border-slate-200 focus:ring-2 focus:ring-blue-500 outline-none font-mono font-bold"
                />
              </div>
              <div>
                <label className="text-[10px] font-bold text-slate-400 uppercase mb-1 block">样品测试类型</label>
                <div className="space-y-1.5">
                  {[
                    { type: 'ACID_CO2', label: '酸解 CO₂', desc: '15分钟测试', color: 'amber' },
                    { type: 'EXCHANGE_CO2', label: '交换后 CO₂', desc: '1小时测试', color: 'indigo' },
                    { type: 'EXCHANGE_O2', label: '交换后 O₂', desc: '2小时测试', color: 'cyan' },
                  ].map((btn) => (
                    <button 
                      key={btn.type}
                      onClick={() => setNewSampleType(btn.type as SampleType)}
                      className={cn(
                        "w-full flex items-center justify-between p-3 border rounded-xl transition-all",
                        newSampleType === btn.type 
                          ? `border-${btn.color}-500 bg-${btn.color}-50 ring-2 ring-${btn.color}-500/20` 
                          : "border-slate-100 hover:border-slate-300"
                      )}
                    >
                      <div className="flex items-center gap-3">
                        <div className={`w-8 h-8 rounded-lg bg-${btn.color}-100 flex items-center justify-center text-${btn.color}-600`}>
                          {btn.type === 'ACID_CO2' ? <FlaskConical className="w-4 h-4" /> : <Wind className="w-4 h-4" />}
                        </div>
                        <div className="text-left">
                          <div className="text-sm font-bold">{btn.label}</div>
                          <div className="text-[10px] text-slate-400 font-mono">{btn.desc}</div>
                        </div>
                      </div>
                      {newSampleType === btn.type && <CheckCircle2 className={`w-4 h-4 text-${btn.color}-500`} />}
                    </button>
                  ))}
                </div>
              </div>
              <button 
                onClick={addSample}
                disabled={!newSampleName.trim()}
                className="w-full py-4 bg-slate-900 text-white rounded-xl font-bold hover:bg-black disabled:opacity-50 transition-all flex items-center justify-center gap-2 shadow-lg"
              >
                <Plus className="w-5 h-5" /> 确认记录样品
              </button>
            </div>
          </section>
        </div>

        {/* 右侧展示区 */}
        <div className="lg:col-span-8 space-y-6">
          
          {/* 数据概览 */}
          <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div className="bg-blue-600 p-5 rounded-2xl text-white shadow-lg relative overflow-hidden group">
              <div className="text-blue-100 text-[10px] font-bold mb-1 uppercase tracking-wider">待测样品数</div>
              <div className="text-4xl font-mono font-bold leading-none">{samples.filter(s => s.status !== 'completed').length} <span className="text-sm font-sans font-normal">个</span></div>
              <FlaskConical className="absolute -bottom-2 -right-2 w-16 h-16 opacity-20 rotate-12 group-hover:scale-110 transition-transform" />
            </div>
            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
              <div className="text-slate-400 text-[10px] font-bold mb-1 uppercase tracking-wider">预计总测试耗时</div>
              <div className="text-4xl font-mono font-bold leading-none">
                {Math.round(timelinePrediction.reduce((acc, curr) => acc + curr.duration, 0) / 60 * 10) / 10} <span className="text-sm font-sans font-normal">h</span>
              </div>
              <Clock className="absolute -bottom-2 -right-2 w-16 h-16 text-slate-100 rotate-12 group-hover:scale-110 transition-transform" />
            </div>
            <div className="bg-white p-5 rounded-2xl border border-slate-200 shadow-sm relative overflow-hidden group">
              <div className="text-slate-400 text-[10px] font-bold mb-1 uppercase tracking-wider">今日最后完成估计</div>
              <div className="text-4xl font-mono font-bold leading-none">
                {timelinePrediction.length > 0 ? format(timelinePrediction[timelinePrediction.length - 1].end, 'HH:mm') : '--:--'}
              </div>
              <MonitorPlay className="absolute -bottom-2 -right-2 w-16 h-16 text-slate-100 rotate-12 group-hover:scale-110 transition-transform" />
            </div>
          </div>

          {/* 上机时间轴 */}
          <section className="bg-slate-900 text-white rounded-2xl shadow-xl p-8 relative overflow-hidden">
            <div className="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 blur-[100px] rounded-full -translate-y-1/2 translate-x-1/2" />
            <h2 className="text-xl font-bold mb-8 flex items-center gap-3 relative z-10">
              <MonitorPlay className="text-blue-400" /> 样品质谱计测试预测时间轴
            </h2>
            
            {timelinePrediction.length === 0 ? (
              <div className="h-48 flex flex-col items-center justify-center text-slate-600 border-2 border-dashed border-slate-800 rounded-2xl">
                <AlertCircle className="w-10 h-10 mb-3 opacity-20" />
                <p className="font-medium">当前无测试序列，请添加样品开始排程</p>
              </div>
            ) : (
              <div className="relative border-l-2 border-slate-800 pl-8 space-y-10">
                <AnimatePresence mode='popLayout'>
                  {timelinePrediction.map((item, index) => (
                    <motion.div 
                      key={item.id}
                      initial={{ opacity: 0, x: -20 }}
                      animate={{ opacity: 1, x: 0 }}
                      exit={{ opacity: 0, scale: 0.95 }}
                      transition={{ delay: index * 0.05 }}
                      className="relative"
                    >
                      <div className="absolute -left-[41px] top-1 w-4 h-4 rounded-full bg-slate-900 border-2 border-blue-500 z-10 shadow-[0_0_10px_rgba(59,130,246,0.5)]" />
                      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
                        <div>
                          <div className="flex items-center gap-2 mb-2">
                            <span className="text-xs font-mono font-bold text-blue-400">{format(item.start, 'HH:mm')}</span>
                            <ChevronRight className="w-3 h-3 text-slate-700" />
                            <span className="text-xs font-mono font-bold text-slate-500">{format(item.end, 'HH:mm')}</span>
                          </div>
                          <h3 className="text-lg font-bold tracking-tight">{item.name}</h3>
                          <div className="flex items-center gap-2 mt-2">
                            {item.type === 'ACID_CO2' && <span className="text-[10px] uppercase font-bold bg-amber-500/20 text-amber-500 border border-amber-500/20 px-2 py-0.5 rounded">酸解-CO₂ (预设15分)</span>}
                            {item.type === 'EXCHANGE_CO2' && <span className="text-[10px] uppercase font-bold bg-indigo-500/20 text-indigo-400 border border-indigo-500/20 px-2 py-0.5 rounded">交换-CO₂ (预设1小时)</span>}
                            {item.type === 'EXCHANGE_O2' && <span className="text-[10px] uppercase font-bold bg-cyan-500/20 text-cyan-400 border border-cyan-500/20 px-2 py-0.5 rounded">交换-O₂ (预设2小时)</span>}
                          </div>
                        </div>
                        <button 
                          onClick={() => updateStatus(item.id, 'completed')}
                          className="group flex items-center gap-2 bg-white/5 hover:bg-white/10 text-white border border-white/10 px-4 py-2 rounded-xl transition-all active:scale-95"
                        >
                          <CheckCircle2 className="w-4 h-4 text-emerald-400 group-hover:scale-110 transition-transform" />
                          <span className="text-sm font-bold">完成测试</span>
                        </button>
                      </div>
                    </motion.div>
                  ))}
                </AnimatePresence>
                <div className="pt-6 mt-6 border-t border-slate-800/50">
                  <div className="flex items-center gap-2 text-[10px] text-slate-500 font-bold uppercase italic">
                    <AlertCircle className="w-3 h-3" />
                    注：测试时间轴仅为排队参考，实际耗时以质谱仪运行为准。
                  </div>
                </div>
              </div>
            )}
          </section>

          {/* 样品池明细 */}
          <section className="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
            <div className="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
              <h2 className="font-bold flex items-center gap-2 text-slate-700 font-sans">
                <Database className="w-4 h-4 text-slate-400" /> 当前样品队列
              </h2>
              <span className="px-2 py-0.5 bg-slate-200 text-slate-600 rounded text-[10px] font-mono font-bold">{samples.length} TOTAL</span>
            </div>
            <div className="divide-y divide-slate-100 max-h-[320px] overflow-y-auto">
              {samples.length === 0 ? (
                <div className="p-12 text-center text-slate-400 italic font-mono text-sm">
                  <p>暂无样品记录，请在左侧登记</p>
                </div>
              ) : (
                samples.map(sample => (
                  <div key={sample.id} className="p-4 flex items-center justify-between hover:bg-slate-50 transition-colors">
                    <div className="flex items-center gap-4">
                      <div className={cn(
                        "w-10 h-10 rounded-xl flex items-center justify-center transition-colors",
                        sample.status === 'completed' ? "bg-emerald-100 text-emerald-600" : "bg-slate-100 text-slate-400"
                      )}>
                        {sample.status === 'completed' ? <CheckCircle2 className="w-5 h-5 shadow-sm" /> : <FlaskConical className="w-5 h-5" />}
                      </div>
                      <div>
                        <div className="font-bold text-slate-700 font-mono">{sample.name}</div>
                        <div className="text-[10px] font-mono text-slate-400">记录时间 {format(sample.recordedAt, 'HH:mm:ss')}</div>
                      </div>
                    </div>
                    <div className="flex items-center gap-4">
                      <div className="text-right">
                        {sample.type === 'ACID_CO2' && <span className="text-[10px] font-bold text-amber-600/70 border border-amber-200 bg-amber-50 px-2 py-0.5 rounded">酸解</span>}
                        {sample.type === 'EXCHANGE_CO2' && <span className="text-[10px] font-bold text-indigo-600/70 border border-indigo-200 bg-indigo-50 px-2 py-0.5 rounded">交换CO2</span>}
                        {sample.type === 'EXCHANGE_O2' && <span className="text-[10px] font-bold text-cyan-600/70 border border-cyan-200 bg-cyan-50 px-2 py-0.5 rounded">交换O2</span>}
                      </div>
                      <button 
                        onClick={() => removeSample(sample.id)}
                        className="text-slate-300 hover:text-red-500 hover:bg-red-50 transition-all p-2 rounded-lg"
                        title="删除记录"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>
        </div>
      </main>

      <footer className="max-w-7xl mx-auto mt-12 py-8 border-t border-slate-200 text-center">
        <p className="text-slate-400 text-xs font-medium">
          地球化学实验室流程管理系统 · 科学助力实验优化
        </p>
      </footer>
    </div>
  );
}